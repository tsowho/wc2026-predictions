const GROUPS = ["A","B","C","D","E","F","G","H","I","J","K","L"];
const ADMIN = "Baba";
const TEAMS = [...new Set(MATCHES.flatMap(m => [m.team1, m.team2]))].sort();
const BONUS_CATS = [
  {id:'winner', label:'Tournament winner', type:'team'},
  {id:'golden_boot', label:'Golden Boot (top scorer)', type:'text'},
  {id:'most_goals', label:'Most goals in a single match', type:'match'},
  {id:'best_group', label:'Best group stage team', type:'team'},
  {id:'finalist1', label:'Finalist #1', type:'team'},
  {id:'finalist2', label:'Finalist #2', type:'team'}
];
const BONUS_PTS = 5;
const WC_START = new Date('2026-06-11T00:00:00-04:00');
const WC_END = new Date('2026-07-19T23:59:59-04:00');
const WC_FINAL_DATE = '2026-07-19';

let state = { players: {}, predictions: {}, actuals: {} };
let bonusPredictions = {};
let bonusActuals = {};
let loginDates = {}; // { playerName: { '2026-06-11': true, '2026-06-12': true, ... } }
let currentPlayer = localStorage.getItem('wc2026_player') || null;
let currentTab = 'dashboard';
let isOnline = false;

// Migrate: ensure admin has a password in Firebase
db.ref('wc2026/passwords/' + ADMIN).once('value').then(snap => {
  if(!snap.val()) db.ref('wc2026/passwords/' + ADMIN).set('2026*');
});

const stateRef = db.ref('wc2026');
stateRef.child('players').on('value', snap => { state.players = snap.val() || {}; updateExistingPlayers(); if(currentPlayer) render(); });
stateRef.child('predictions').on('value', snap => { state.predictions = snap.val() || {}; if(currentPlayer) render(); });
stateRef.child('actuals').on('value', snap => { state.actuals = snap.val() || {}; if(currentPlayer) render(); });
stateRef.child('bonus').on('value', snap => { bonusPredictions = snap.val() || {}; if(currentPlayer) render(); });
stateRef.child('bonusActuals').on('value', snap => { bonusActuals = snap.val() || {}; if(currentPlayer) render(); });
stateRef.child('loginDates').on('value', snap => { loginDates = snap.val() || {}; if(currentPlayer) render(); });
let chatMessages = [];
stateRef.child('chat').orderByChild('ts').limitToLast(100).on('value', snap => { chatMessages = []; snap.forEach(s => { chatMessages.push(Object.assign({key: s.key}, s.val())); }); if(currentPlayer && currentTab === 'chat') render(); });
db.ref('.info/connected').on('value', snap => { isOnline = snap.val() === true; updateSyncStatus(); });

function updateSyncStatus() {
  const el = document.getElementById('syncStatus');
  el.innerHTML = isOnline
    ? '<span class="sync-status sync-online">&#9679; Synced live</span>'
    : '<span class="sync-status sync-offline">&#9679; Offline</span>';
}

function updateExistingPlayers() {
  const el = document.getElementById('existingPlayers');
  if(!el) return;
  const players = Object.keys(state.players).filter(p => p !== ADMIN);
  if(!players.length) { el.innerHTML = ''; return; }
  el.innerHTML = '<p style="font-size:13px;color:var(--muted);margin-bottom:8px">Or pick your name:</p>' +
    '<div class="player-list" style="justify-content:center">' +
    players.map(p => '<button class="player-chip" onclick="loginAs(\'' + p.replace(/'/g, "\\'") + '\')" style="cursor:pointer;border:none">' + chessIcon(p) + p + '</button>').join('') +
    '</div>';
}

function getETDate() {
  return new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' }); // returns YYYY-MM-DD in ET
}
function recordLogin(name) {
  const now = new Date();
  if(now < WC_START || now > WC_END) return;
  const today = getETDate();
  db.ref('wc2026/loginDates/' + name + '/' + today).set(true);
}
window.claimStreak = function() {
  if(!currentPlayer) return;
  var now = new Date();
  if(now < WC_START || now > WC_END) return;
  var today = getETDate();
  var already = loginDates[currentPlayer] && loginDates[currentPlayer][today];
  if(already) return;
  db.ref('wc2026/loginDates/' + currentPlayer + '/' + today).set(true);
  // Force hero refresh
  _heroHash = '';
  renderHero();
};
function getStreakInfo(name) {
  const dates = loginDates[name] || {};
  const now = new Date();
  if(now < WC_START) return { streak: 0, total: 0, days: [], active: false, started: false };
  const endDate = now > WC_END ? WC_END : now;
  // Build array of all WC days up to today
  const allDays = [];
  const d = new Date(WC_START);
  while(d <= endDate) {
    allDays.push(d.toLocaleDateString('en-CA', { timeZone: 'America/New_York' }));
    d.setDate(d.getDate() + 1);
  }
  // Calculate current streak (counting backwards from today/latest)
  let streak = 0;
  for(let i = allDays.length - 1; i >= 0; i--) {
    if(dates[allDays[i]]) streak++;
    else break;
  }
  // Total logged days
  const total = Object.keys(dates).length;
  // Build day status array for display
  const days = allDays.map(day => ({ date: day, logged: !!dates[day] }));
  const tournamentOver = now > WC_END;
  return { streak, total, days, active: streak > 0, started: true, tournamentOver };
}
function completeLogin(name) {
  currentPlayer = name;
  localStorage.setItem('wc2026_player', name);
  document.getElementById('loginScreen').classList.add('hidden');
  document.getElementById('mainApp').classList.remove('hidden');
  render();
}

function loginAs(name) {
  // Returning player — check password
  db.ref('wc2026/passwords/' + name).once('value').then(snap => {
    const stored = snap.val();
    if(!stored) { alert('Player not found.'); return; }
    const pw = prompt('Enter your password:');
    if(pw !== stored) { alert('Wrong password.'); return; }
    completeLogin(name);
  });
}

document.getElementById('loginBtn').addEventListener('click', () => {
  const name = document.getElementById('loginName').value.trim();
  if(!name) return;
  // Check if player already exists
  db.ref('wc2026/passwords/' + name).once('value').then(snap => {
    if(snap.val()) {
      // Existing player — ask for password
      const pw = prompt('Enter your password:');
      if(pw !== snap.val()) { alert('Wrong password.'); return; }
      completeLogin(name);
      return;
    }
    // New player — set a password
    const pw = prompt('Set a password for your account:');
    if(!pw) return;
    const pw2 = prompt('Confirm your password:');
    if(pw !== pw2) { alert('Passwords don\'t match. Try again.'); return; }
    db.ref('wc2026/passwords/' + name).set(pw);
    db.ref('wc2026/players/' + name).set(true);
    db.ref('wc2026/joinTimes/' + name).set(Date.now());
    completeLogin(name);
  });
});
document.getElementById('loginName').addEventListener('keydown', e => { if(e.key === 'Enter') document.getElementById('loginBtn').click(); });

// Login countdown timer
function updateLoginCountdown() {
  var el = document.getElementById('loginCountdown');
  if(!el) return;
  var now = new Date();
  var target = WC_START;
  // Find next match if tournament started
  if(now >= WC_START) {
    var nm = MATCHES.find(function(m) { return !state.actuals?.['m' + m.id] && getMatchTime(m) > now; });
    if(nm) target = getMatchTime(nm);
    else { el.innerHTML = '<div style="font-size:13px;opacity:0.5">Tournament complete!</div>'; return; }
  }
  var diff = target - now;
  if(diff <= 0) { el.innerHTML = ''; return; }
  var d = Math.floor(diff / 86400000), hr = Math.floor((diff % 86400000) / 3600000), mn = Math.floor((diff % 3600000) / 60000);
  var label = now < WC_START ? 'Kickoff in' : 'Next match';
  el.innerHTML = '<div style="font-size:10px;opacity:0.4;width:100%;text-align:center;margin-bottom:4px">' + label + '</div>' +
    (d > 0 ? '<div class="login-cd-box"><div class="login-cd-num">' + d + '</div><div class="login-cd-unit">days</div></div>' : '') +
    '<div class="login-cd-box"><div class="login-cd-num">' + hr + '</div><div class="login-cd-unit">hrs</div></div>' +
    '<div class="login-cd-box"><div class="login-cd-num">' + mn + '</div><div class="login-cd-unit">min</div></div>';
}
updateLoginCountdown();
setInterval(updateLoginCountdown, 60000);

// Update player count on login screen
function updateLoginPlayerCount() {
  var el = document.getElementById('loginPlayerCount');
  if(!el) return;
  var count = Object.keys(state.players || {}).filter(function(p) { return p !== ADMIN; }).length;
  el.textContent = count > 0 ? count + ' friend' + (count !== 1 ? 's' : '') + ' predicting' : '';
}
stateRef.child('players').on('value', function() { updateLoginPlayerCount(); });
updateLoginPlayerCount();

if(currentPlayer) {
  document.getElementById('loginScreen').classList.add('hidden');
  document.getElementById('mainApp').classList.remove('hidden');
}

document.getElementById('tabs').addEventListener('click', e => {
  if(!e.target.classList.contains('tab')) return;
  currentTab = e.target.dataset.tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  e.target.classList.add('active');
  render();
});

let newsCache = null;
let newsLastFetch = 0;
function renderNews() {
  let h = '<div class="card"><h2>World Cup 2026 News</h2><p style="font-size:13px;color:var(--muted);margin-bottom:12px">Live headlines from Google News. Auto-refreshes every 5 minutes.</p>';
  h += '<div id="newsContainer">';
  if(newsCache && newsCache.length) {
    newsCache.forEach(item => {
      const ago = timeAgo(new Date(item.pubDate));
      h += '<div style="padding:12px 0;border-bottom:1px solid var(--border)">';
      h += '<a href="' + item.link + '" target="_blank" rel="noopener" style="font-size:15px;font-weight:500;color:var(--accent);text-decoration:none">' + item.title + '</a>';
      h += '<div style="font-size:12px;color:var(--muted);margin-top:4px">' + (item.author || 'Unknown source') + ' &middot; ' + ago + '</div>';
      h += '</div>';
    });
  } else {
    h += '<div class="empty">Loading news...</div>';
  }
  h += '</div></div>';
  fetchNews();
  return h;
}
function fetchNews() {
  const now = Date.now();
  if(newsCache && now - newsLastFetch < 300000) return; // 5 min cache
  fetch('https://api.rss2json.com/v1/api.json?rss_url=' + encodeURIComponent('https://news.google.com/rss/search?q=FIFA+World+Cup+2026&hl=en-US&gl=US&ceid=US:en'))
    .then(r => r.json()).then(data => {
      if(data.items) {
        newsCache = data.items.slice(0, 12);
        newsLastFetch = Date.now();
        if(currentTab === 'news') {
          const c = document.getElementById('newsContainer');
          if(c) {
            let nh = '';
            newsCache.forEach(item => {
              const ago = timeAgo(new Date(item.pubDate));
              nh += '<div style="padding:12px 0;border-bottom:1px solid var(--border)">';
              nh += '<a href="' + item.link + '" target="_blank" rel="noopener" style="font-size:15px;font-weight:500;color:var(--accent);text-decoration:none">' + item.title + '</a>';
              nh += '<div style="font-size:12px;color:var(--muted);margin-top:4px">' + (item.author || 'Unknown source') + ' &middot; ' + ago + '</div>';
              nh += '</div>';
            });
            c.innerHTML = nh;
          }
        }
      }
    }).catch(() => {});
}
function timeAgo(date) {
  const s = Math.floor((Date.now() - date) / 1000);
  if(s < 60) return 'just now';
  if(s < 3600) return Math.floor(s / 60) + 'm ago';
  if(s < 86400) return Math.floor(s / 3600) + 'h ago';
  return Math.floor(s / 86400) + 'd ago';
}
setInterval(() => { if(currentTab === 'news') fetchNews(); }, 300000);

function render() {
  const c = document.getElementById('content');
  switch(currentTab) {
    case 'dashboard': c.innerHTML = renderDashboard(); break;
    case 'live': c.innerHTML = renderLive(); break;
    case 'predict': c.innerHTML = renderPredict(); break;
    case 'results': c.innerHTML = renderResults(); break;
    case 'leaderboard': c.innerHTML = renderLeaderboard(); break;
    case 'news': c.innerHTML = renderNews(); break;
    case 'knockout': c.innerHTML = renderKnockout(); break;
    case 'chat': c.innerHTML = renderChat(); break;
    case 'players': c.innerHTML = renderPlayers(); break;
  }
  attachEvents();
}

function getMatchTime(m) { return new Date(m.date + 'T' + m.time + ':00-04:00'); }
function getCountdown(m) {
  const diff = getMatchTime(m) - new Date();
  if(diff <= 0) return 'Started';
  const d = Math.floor(diff / 86400000), h = Math.floor((diff % 86400000) / 3600000);
  if(d > 0) return d + 'd ' + h + 'h';
  return h + 'h ' + Math.floor((diff % 3600000) / 60000) + 'm';
}
function isMatchStarted(m) { return new Date() >= getMatchTime(m); }
function isPredLocked(player, mid) { const p = state.predictions?.[player]?.['m' + mid]; return p && p.locked; }

function calcPoints(pred, actual) {
  if(!pred || !actual || actual.s1 === undefined || actual.s2 === undefined || actual.s1 === '' || actual.s2 === '') return null;
  const ps1 = parseInt(pred.s1), ps2 = parseInt(pred.s2), as1 = parseInt(actual.s1), as2 = parseInt(actual.s2);
  if(isNaN(ps1) || isNaN(ps2) || isNaN(as1) || isNaN(as2)) return null;
  if(ps1 === as1 && ps2 === as2) return { pts: 3, type: 'exact' };
  if(Math.sign(ps1 - ps2) === Math.sign(as1 - as2)) return { pts: 1, type: 'correct' };
  return { pts: 0, type: 'wrong' };
}

function getLeaderboard(includeAdmin) {
  const showAdmin = includeAdmin || currentPlayer === ADMIN;
  return Object.keys(state.players || {}).filter(p => showAdmin || p !== ADMIN).map(p => {
    let total = 0, exact = 0, correct = 0, wrong = 0, predicted = 0;
    MATCHES.forEach(m => {
      const pred = state.predictions?.[p]?.['m' + m.id];
      if(!pred || !pred.locked) return;
      const r = calcPoints(pred, state.actuals?.['m' + m.id]);
      if(!r) return;
      predicted++; total += r.pts;
      if(r.type === 'exact') exact++; else if(r.type === 'correct') correct++; else wrong++;
    });
    // Bonus points
    let bonusPts = 0;
    const pb = bonusPredictions[p];
    if(pb && pb._locked) {
      BONUS_CATS.forEach(cat => {
        if(bonusActuals[cat.id] !== undefined && bonusActuals[cat.id] !== '' && pb[cat.id] && pb[cat.id] === bonusActuals[cat.id]) bonusPts += BONUS_PTS;
      });
    }
    total += bonusPts;
    // Knockout stage points
    let koPts = 0;
    const playerKo = koPredictions[p];
    if(playerKo) { KO_SLOTS.forEach(function(slot) { var pred = playerKo[slot.id]; var actual = koActuals[slot.id]; if(pred && pred.locked && actual) { var r = calcPoints(pred, actual); if(r) koPts += r.pts; } }); }
    total += koPts;
    // Login streak points (only added after tournament ends)
    const si = getStreakInfo(p);
    const streakPts = si.tournamentOver ? si.streak : 0;
    total += streakPts;
    return { name: p, total, exact, correct, wrong, predicted, bonusPts, streakPts, streakCurrent: si.streak };
  }).sort((a, b) => b.total - a.total || b.exact - a.exact);
}

function fmtDate(ds) { return new Date(ds + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }); }

// Celebration helpers
function getStreak(player) {
  let streak = 0;
  const sorted = MATCHES.filter(m => state.actuals?.['m' + m.id] && state.predictions?.[player]?.['m' + m.id]?.locked)
    .sort((a, b) => getMatchTime(b) - getMatchTime(a));
  for(const m of sorted) {
    const r = calcPoints(state.predictions[player]['m' + m.id], state.actuals['m' + m.id]);
    if(r && r.pts > 0) streak++; else break;
  }
  return streak;
}

function getLoseStreak(player) {
  let streak = 0;
  const sorted = MATCHES.filter(m => state.actuals?.['m' + m.id] && state.predictions?.[player]?.['m' + m.id]?.locked)
    .sort((a, b) => getMatchTime(b) - getMatchTime(a));
  for(const m of sorted) {
    const r = calcPoints(state.predictions[player]['m' + m.id], state.actuals['m' + m.id]);
    if(r && r.pts === 0) streak++; else break;
  }
  return streak;
}

function streakBadge(player) {
  const s = getStreak(player);
  if(s < 2) return '';
  const flames = s >= 10 ? '&#128293;&#128293;&#128293;' : s >= 5 ? '&#128293;&#128293;' : '&#128293;';
  return '<span class="streak-badge">' + s + ' in a row ' + flames + '</span>';
}

function getAchievements(player) {
  const preds = state.predictions?.[player] || {};
  let exactCount = 0, totalCorrect = 0;
  MATCHES.forEach(m => {
    const pred = preds['m' + m.id];
    if(!pred || !pred.locked) return;
    const r = calcPoints(pred, state.actuals?.['m' + m.id]);
    if(!r) return;
    if(r.type === 'exact') exactCount++;
    if(r.pts > 0) totalCorrect++;
  });
  const achs = [];
  if(exactCount >= 5) achs.push('<span class="achievement ach-oracle">Oracle</span>');
  if(getStreak(player) >= 3) achs.push('<span class="achievement ach-streaker">Streaker</span>');
  if(getLoseStreak(player) >= 5) achs.push('<span class="achievement ach-cursed">Cursed</span>');
  return achs.join('');
}

function getMatchMVP(matchId) {
  const actual = state.actuals?.['m' + matchId];
  if(!actual || actual.s1 === undefined) return null;
  let best = null, bestType = -1, bestTime = Infinity;
  Object.keys(state.players || {}).forEach(p => {
    const pred = state.predictions?.[p]?.['m' + matchId];
    if(!pred || !pred.locked) return;
    const r = calcPoints(pred, actual);
    if(!r) return;
    const rank = r.type === 'exact' ? 2 : r.type === 'correct' ? 1 : 0;
    if(rank > bestType || (rank === bestType && (pred.lockedAt || 0) < bestTime)) {
      best = p; bestType = rank; bestTime = pred.lockedAt || 0;
    }
  });
  return bestType >= 1 ? best : null;
}

// Position tracking
let prevPositions = {};
function getPositionChanges() {
  const lb = getLeaderboard();
  const changes = {};
  lb.forEach((p, i) => {
    const prev = prevPositions[p.name];
    if(prev !== undefined) changes[p.name] = prev - i;
    else changes[p.name] = 0;
  });
  lb.forEach((p, i) => prevPositions[p.name] = i);
  return changes;
}

function posArrow(change) {
  if(change > 0) return '<span class="pos-up">&#9650; ' + change + '</span>';
  if(change < 0) return '<span class="pos-down">&#9660; ' + Math.abs(change) + '</span>';
  return '<span class="pos-same">&#8212;</span>';
}

// Confetti
function fireConfetti() {
  const canvas = document.createElement('canvas');
  canvas.className = 'confetti-canvas';
  document.body.appendChild(canvas);
  const ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  const pieces = [];
  const colors = ['#BA7517','#1d9e75','#378add','#7f77dd','#e24b4a','#D85A30','#5DCAA5'];
  for(let i = 0; i < 150; i++) {
    pieces.push({
      x: Math.random() * canvas.width, y: -20 - Math.random() * 200,
      w: 6 + Math.random() * 6, h: 4 + Math.random() * 4,
      vx: (Math.random() - 0.5) * 6, vy: 2 + Math.random() * 4,
      rot: Math.random() * 360, vr: (Math.random() - 0.5) * 10,
      color: colors[Math.floor(Math.random() * colors.length)],
      opacity: 1
    });
  }
  let frame = 0;
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    let alive = false;
    pieces.forEach(p => {
      if(p.y > canvas.height + 50) return;
      alive = true;
      p.x += p.vx; p.y += p.vy; p.rot += p.vr;
      p.vy += 0.1; p.vx *= 0.99;
      if(frame > 60) p.opacity = Math.max(0, p.opacity - 0.01);
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot * Math.PI / 180);
      ctx.globalAlpha = p.opacity;
      ctx.fillStyle = p.color;
      ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
      ctx.restore();
    });
    frame++;
    if(alive && frame < 200) requestAnimationFrame(draw);
    else canvas.remove();
  }
  requestAnimationFrame(draw);
}

// Track if we already fired confetti for a match
let confettiFired = {};

// Reactions
window.addReaction = function(matchId, emoji) {
  const path = 'wc2026/reactions/m' + matchId + '/' + currentPlayer;
  db.ref(path).once('value').then(snap => {
    const current = snap.val();
    if(current === emoji) db.ref(path).remove();
    else db.ref(path).set(emoji);
  });
};

// Listen for reactions
let reactions = {};
db.ref('wc2026/reactions').on('value', snap => { reactions = snap.val() || {}; if(currentPlayer) render(); });

// Join timestamps
let joinTimes = {};
db.ref('wc2026/joinTimes').on('value', snap => { joinTimes = snap.val() || {}; });

// Chess rank system — based on leaderboard position
const CHESS_RANKS = [
  { piece: '&#9812;', name: 'King',   cls: 'rank-king' },   // Admin only
  { piece: '&#9813;', name: 'Queen',  cls: 'rank-queen' },  // 1st
  { piece: '&#9814;', name: 'Rook',   cls: 'rank-rook' },   // 2nd-3rd
  { piece: '&#9815;', name: 'Bishop', cls: 'rank-bishop' },  // 4th-5th
  { piece: '&#9816;', name: 'Knight', cls: 'rank-knight' },  // 6th-7th
  { piece: '&#9817;', name: 'Pawn',   cls: 'rank-pawn' }     // 8th+
];

let prevRanks = {};
function getChessRank(playerName) {
  if(playerName === ADMIN) return CHESS_RANKS[0]; // King (admin)
  const lb = getLeaderboard(true);
  const entry = lb.find(p => p.name === playerName);
  if(!entry || entry.total === 0) return CHESS_RANKS[5]; // Pawn until you earn points
  const idx = lb.indexOf(entry);
  if(idx === 0) return CHESS_RANKS[0]; // King — 1st place
  if(idx === 1) return CHESS_RANKS[1]; // Queen — 2nd
  if(idx <= 3) return CHESS_RANKS[2]; // Rook — 3rd-4th
  if(idx <= 5) return CHESS_RANKS[3]; // Bishop — 5th-6th
  if(idx <= 7) return CHESS_RANKS[4]; // Knight — 7th-8th
  return CHESS_RANKS[5]; // Pawn
}

function chessIcon(playerName) {
  const rank = getChessRank(playerName);
  const wasPromoted = prevRanks[playerName] && prevRanks[playerName] !== rank.name && CHESS_RANKS.findIndex(r => r.name === rank.name) < CHESS_RANKS.findIndex(r => r.name === prevRanks[playerName]);
  prevRanks[playerName] = rank.name;
  return '<span class="chess-piece' + (wasPromoted ? ' promotion-anim' : '') + '" title="' + rank.name + '">' + rank.piece + '</span>';
}

function chessLabel(playerName) {
  const rank = getChessRank(playerName);
  return '<span class="chess-rank-label ' + rank.cls + '">' + rank.name + '</span>';
}

function renderDashboard() {
  const lb = getLeaderboard(), leader = lb[0], played = Object.keys(state.actuals || {}).length, players = Object.keys(state.players || {});
  let h = '<div class="stats-row">';
  h += '<div class="stat-card"><div class="label">Players</div><div class="value">' + players.length + '</div></div>';
  h += '<div class="stat-card"><div class="label">Matches played</div><div class="value">' + played + ' / ' + MATCHES.length + '</div></div>';
  h += '<div class="stat-card"><div class="label">Leader</div><div class="value">' + (leader && leader.total > 0 ? leader.name : '-') + '</div></div>';
  h += '<div class="stat-card"><div class="label">Top score</div><div class="value">' + (leader && leader.total > 0 ? leader.total + ' pts' : '-') + '</div></div></div>';
  h += '<div style="text-align:center;margin-bottom:16px;font-size:13px;color:var(--muted)">Logged in as ' + chessIcon(currentPlayer) + '<strong>' + currentPlayer + '</strong> ' + chessLabel(currentPlayer) + ' <button class="btn-sm" onclick="logout()" style="margin-left:8px">Switch</button></div>';
  if(!players.length) return h + '<div class="card"><div class="empty">Share the link to get friends to join!</div></div>';
  if(lb.length) {
    h += '<div class="card"><h2>Leaderboard</h2><table><tr><th>#</th><th>Player</th><th style="text-align:right">Exact</th><th style="text-align:right">Correct</th><th style="text-align:right">Points</th></tr>';
    lb.forEach((p, i) => { h += '<tr><td class="' + (i < 3 ? 'rank-' + (i + 1) : '') + '">' + (i + 1) + '</td><td>' + chessIcon(p.name) + p.name + '</td><td style="text-align:right">' + p.exact + '</td><td style="text-align:right">' + p.correct + '</td><td style="text-align:right;font-weight:600">' + p.total + '</td></tr>'; });
    h += '</table></div>';
  }
  const nm = MATCHES.find(m => !state.actuals?.['m' + m.id]);
  if(nm) {
    h += '<div class="card"><h2>Next match</h2>';
    h += '<div class="match-header"><span>Group ' + nm.group + '</span><span class="countdown">' + getCountdown(nm) + '</span></div>';
    h += '<div class="match-teams"><span class="team">' + nm.team1 + '</span><span class="match-vs">vs</span><span class="team">' + nm.team2 + '</span></div>';
    h += '<div style="text-align:center;margin-top:8px;font-size:12px;color:var(--hint)">' + nm.venue + '<br>' + fmtDate(nm.date) + ' ' + nm.time + ' ET</div>';
    h += isPredLocked(currentPlayer, nm.id) ? '<div style="text-align:center;margin-top:8px"><span class="locked-badge">Your prediction is locked</span></div>' : '<div style="text-align:center;margin-top:8px"><span style="font-size:12px;color:var(--danger)">You haven\'t predicted this match yet!</span></div>';
    h += '</div>';
  }
  return h;
}

function renderLive() {
  const now = new Date(), players = Object.keys(state.players || {}).filter(p => currentPlayer === ADMIN || p !== ADMIN);
  const live = MATCHES.filter(m => { const t = getMatchTime(m); return now >= t && now <= new Date(t.getTime() + 7200000); });
  const todayAll = MATCHES.filter(m => { const t = getMatchTime(m); return t.toDateString() === now.toDateString(); });
  const upcoming = todayAll.filter(m => !live.includes(m));
  let h = '';
  if(live.length) { h += '<div class="card"><h2><span class="live-badge">LIVE</span> Matches in progress</h2>'; live.forEach(m => h += liveCard(m, players)); h += '</div>'; }
  if(upcoming.length) { h += '<div class="card"><h2>Today\'s matches</h2>'; upcoming.forEach(m => h += liveCard(m, players)); h += '</div>'; }
  if(!live.length && !upcoming.length) {
    const next = MATCHES.filter(m => !isMatchStarted(m)).slice(0, 6);
    h += '<div class="card"><h2>Upcoming matches</h2>';
    if(next.length) next.forEach(m => h += liveCard(m, players));
    else h += '<div class="empty">No upcoming matches</div>';
    h += '</div>';
  }
  return h;
}

function liveCard(m, players) {
  const actual = state.actuals?.['m' + m.id], started = isMatchStarted(m);
  const mvp = getMatchMVP(m.id);
  const matchReactions = reactions['m' + m.id] || {};
  let h = '<div class="match-card"><div class="match-header"><span>Group ' + m.group + ' | ' + fmtDate(m.date) + ' ' + m.time + ' ET</span>';
  h += started && !actual ? '<span class="live-badge">LIVE</span>' : !started ? '<span class="countdown">' + getCountdown(m) + '</span>' : '';
  h += '</div><div class="match-teams"><span class="team">' + m.team1 + '</span>';
  h += actual && actual.s1 !== undefined ? '<div class="match-score"><span style="font-size:20px;font-weight:700">' + actual.s1 + ' - ' + actual.s2 + '</span></div>' : '<span class="match-vs">vs</span>';
  h += '<span class="team">' + m.team2 + '</span></div>';
  h += '<div style="margin-top:10px;border-top:1px dashed var(--border);padding-top:8px"><div style="font-size:11px;color:var(--hint);margin-bottom:6px">Everyone\'s predictions:</div><div class="pred-grid">';
  players.forEach(p => {
    const pred = state.predictions?.[p]?.['m' + m.id];
    if(!pred || !pred.locked) { h += '<div class="pred-item"><span class="name">' + chessIcon(p) + p + '</span><span style="color:var(--hint)">-</span></div>'; return; }
    if(started || actual) {
      const r = calcPoints(pred, actual);
      const s = r ? (r.type === 'exact' ? 'color:#0f6e56;font-weight:700' : r.type === 'correct' ? 'color:#854f0b;font-weight:600' : 'color:var(--danger)') : '';
      const isMvp = p === mvp;
      const isExact = r && r.type === 'exact';
      const nameClass = isExact ? ' gold-glow' : '';
      h += '<div class="pred-item"><span class="name' + nameClass + '">' + chessIcon(p) + p + (isMvp ? '<span class="mvp-crown" title="Match MVP">&#128081;</span>' : '') + '</span><span style="' + s + '">' + pred.s1 + '-' + pred.s2 + (isExact ? ' &#127919;' : '') + '</span></div>';
      // Fire confetti for exact predictions
      if(isExact && p === currentPlayer && !confettiFired['m' + m.id]) { confettiFired['m' + m.id] = true; setTimeout(fireConfetti, 500); }
    } else {
      h += '<div class="pred-item"><span class="name">' + chessIcon(p) + p + '</span><span style="color:var(--accent)">Locked</span></div>';
    }
  });
  h += '</div>';
  // Reactions bar (only for started/completed matches)
  if(started || actual) {
    const emojis = ['&#128514;','&#128079;','&#128166;','&#128561;','&#129325;'];
    const emojiLabels = ['laugh','clap','sweat','shock','clown'];
    h += '<div class="reaction-bar">';
    emojis.forEach((e, idx) => {
      const reactors = Object.entries(matchReactions).filter(([k, v]) => v === emojiLabels[idx]);
      const isActive = matchReactions[currentPlayer] === emojiLabels[idx];
      h += '<button class="reaction-btn' + (isActive ? ' active' : '') + '" onclick="addReaction(' + m.id + ',\'' + emojiLabels[idx] + '\')">' + e + (reactors.length > 0 ? '<span class="reaction-count">' + reactors.length + '</span>' : '') + '</button>';
    });
    h += '</div>';
  }
  h += '</div></div>';
  return h;
}

function renderPredict() {
  let h = '<div class="flex-between" style="margin-bottom:16px"><div style="font-size:14px">Predicting as ' + chessIcon(currentPlayer) + '<strong>' + currentPlayer + '</strong> ' + chessLabel(currentPlayer) + '</div>';
  h += '<div class="group-filter" id="groupFilter"><button class="group-btn" data-group="all">All</button>';
  GROUPS.forEach(function(g) {
    var teams = MATCHES.filter(function(m){return m.group===g}).map(function(m){return m.team1});
    teams = teams.filter(function(t,i){return teams.indexOf(t)===i}).slice(0,4);
    h += '<button class="group-btn' + (g === 'A' ? ' active' : '') + '" data-group="' + g + '" title="' + teams.join(', ') + '">' + g + '</button>';
  });
  h += '</div></div>';
  h += '<div class="card" style="padding:10px 16px;margin-bottom:16px"><p style="font-size:13px;color:var(--muted)">Enter your predicted score and click <strong>Lock</strong> to submit. Locked predictions cannot be changed. Predictions are hidden from others until the match starts.</p></div>';
  // Bonus predictions section
  const myBonus = bonusPredictions[currentPlayer] || {};
  const bonusDeadline = new Date('2026-06-27T23:59:59-04:00'); // Last group stage day ET
  const bonusClosed = new Date() > bonusDeadline;
  const bonusLocked = myBonus._locked || bonusClosed;
  var bonusFilled = BONUS_CATS.filter(function(c){ return myBonus[c.id]; }).length;
  var bonusSummary = bonusLocked ? 'Locked (' + bonusFilled + '/' + BONUS_CATS.length + ')' : bonusClosed ? 'Closed' : bonusFilled + '/' + BONUS_CATS.length + ' filled';
  h += '<div class="card" style="margin-bottom:16px"><div style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 0" onclick="var bd=document.getElementById(\'bonusBody\');var ar=document.getElementById(\'bonusArrow\');if(bd.style.display===\'none\'){bd.style.display=\'block\';ar.textContent=\'\u25B2\'}else{bd.style.display=\'none\';ar.textContent=\'\u25BC\'}">' +
    '<h2 style="margin:0">Bonus Predictions <span style="font-size:13px;color:var(--muted);font-weight:400">(+' + BONUS_PTS + ' pts each)</span></h2>' +
    '<div style="display:flex;align-items:center;gap:8px"><span style="font-size:12px;color:var(--muted)">' + bonusSummary + '</span><span id="bonusArrow" style="font-size:14px;color:var(--muted)">\u25BC</span></div></div>';
  h += '<div id="bonusBody" style="display:none;margin-top:10px">';
  h += '<p style="font-size:13px;color:var(--danger);margin-bottom:10px">Closes after Group Stage (June 27) — get your bonus predictions in!</p>';
  if(bonusClosed && !myBonus._locked) h += '<div style="margin-bottom:10px"><span class="result-badge result-wrong">Bonus predictions closed</span></div>';
  else if(bonusLocked) h += '<div style="margin-bottom:10px"><span class="locked-badge">Locked</span></div>';
  BONUS_CATS.forEach(cat => {
    const val = myBonus[cat.id] || '';
    h += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap"><label style="min-width:200px;font-size:14px">' + cat.label + '</label>';
    if(cat.type === 'team') {
      h += '<select class="bonus-input" data-cat="' + cat.id + '"' + (bonusLocked ? ' disabled' : '') + '><option value="">-- Select --</option>';
      TEAMS.forEach(t => h += '<option value="' + t + '"' + (val === t ? ' selected' : '') + '>' + t + '</option>');
      h += '</select>';
    } else if(cat.type === 'match') {
      h += '<select class="bonus-input" data-cat="' + cat.id + '"' + (bonusLocked ? ' disabled' : '') + '><option value="">-- Select --</option>';
      MATCHES.forEach(m => { const lbl = m.team1 + ' vs ' + m.team2; h += '<option value="m' + m.id + '"' + (val === 'm' + m.id ? ' selected' : '') + '>' + lbl + '</option>'; });
      h += '</select>';
    } else {
      h += '<input type="text" class="bonus-input" data-cat="' + cat.id + '" value="' + (val || '') + '" placeholder="Type your prediction"' + (bonusLocked ? ' disabled' : '') + ' style="max-width:250px"/>';
    }
    // Show result if actuals exist
    if(bonusActuals[cat.id] !== undefined && bonusActuals[cat.id] !== '' && bonusLocked) {
      const correct = val && val === bonusActuals[cat.id];
      h += '<span class="result-badge ' + (correct ? 'result-exact' : 'result-wrong') + '">' + (correct ? '+' + BONUS_PTS : '0') + '</span>';
    }
    h += '</div>';
  });
  if(!bonusLocked) h += '<button class="btn-primary" onclick="lockBonus()">Lock Bonus Predictions</button>';
  else if(!bonusClosed && myBonus._locked) {} // already locked, nothing extra
  else if(bonusClosed && !myBonus._locked) h += '<p style="font-size:13px;color:var(--muted);margin-top:8px">You missed the deadline. No bonus points will be awarded.</p>';
  h += '</div></div>';
  MATCHES.forEach(m => {
    // Hide matches that already have results entered
    if(state.actuals?.['m' + m.id]) return;
    const pred = state.predictions?.[currentPlayer]?.['m' + m.id] || {}, locked = pred.locked, started = isMatchStarted(m), result = calcPoints(pred, state.actuals?.['m' + m.id]);
    h += '<div class="match-card" data-group="' + m.group + '"' + (m.group !== 'A' ? ' style="display:none"' : '') + '><div class="match-header"><span>Group ' + m.group + ' | ' + fmtDate(m.date) + ' ' + m.time + ' ET</span>';
    h += locked ? '<span class="locked-badge">Locked</span>' : started ? '<span style="font-size:11px;color:var(--danger)">Match started</span>' : '<span class="countdown">' + getCountdown(m) + '</span>';
    h += '</div><div class="match-teams"><span class="team">' + m.team1 + '</span><div class="match-score">';
    h += '<input type="number" min="0" max="20" value="' + (pred.s1 ?? '') + '" data-match="' + m.id + '" data-side="s1" class="pred-input"' + (locked || started ? ' disabled' : '') + '/>';
    h += '<span class="match-vs">-</span>';
    h += '<input type="number" min="0" max="20" value="' + (pred.s2 ?? '') + '" data-match="' + m.id + '" data-side="s2" class="pred-input"' + (locked || started ? ' disabled' : '') + '/>';
    if(!locked && !started) h += '<button class="btn-lock" onclick="lockPrediction(' + m.id + ')">Lock</button>';
    h += '</div><span class="team">' + m.team2 + '</span></div>';
    if(result) { const cls = result.type === 'exact' ? 'result-exact' : result.type === 'correct' ? 'result-correct' : 'result-wrong'; const lbl = result.type === 'exact' ? 'Exact! +3' : result.type === 'correct' ? 'Correct result +1' : 'Wrong 0'; h += '<div style="text-align:center;margin-top:8px"><span class="result-badge ' + cls + '">' + lbl + '</span></div>'; }
    h += '</div>';
  });
  return h;
}

function renderResults() {
  const isAdmin = currentPlayer === ADMIN;
  let h = isAdmin
    ? '<div class="card"><h2>Enter actual results</h2><p style="font-size:13px;color:var(--muted);margin-bottom:16px">Enter real match scores after each game.</p></div>'
    : '<div class="card"><h2>Match results</h2><p style="font-size:13px;color:var(--muted);margin-bottom:16px">Only the admin (Baba) can enter results.</p></div>';
  h += '<div class="group-filter" id="groupFilter"><button class="group-btn active" data-group="all">All</button>';
  GROUPS.forEach(g => h += '<button class="group-btn" data-group="' + g + '">' + g + '</button>');
  h += '</div>';
  MATCHES.forEach(m => {
    const actual = state.actuals?.['m' + m.id] || {}, hasA = actual.s1 !== undefined && actual.s1 !== '';
    h += '<div class="match-card" data-group="' + m.group + '"><div class="match-header"><span>Group ' + m.group + ' | ' + fmtDate(m.date) + '</span><span>' + m.venue + '</span></div>';
    h += '<div class="match-teams"><span class="team">' + m.team1 + '</span><div class="match-score">';
    if(isAdmin) { h += '<input type="number" min="0" max="20" value="' + (actual.s1 ?? '') + '" data-match="' + m.id + '" data-side="s1" class="actual-input"/><span class="match-vs">-</span><input type="number" min="0" max="20" value="' + (actual.s2 ?? '') + '" data-match="' + m.id + '" data-side="s2" class="actual-input"/>'; }
    else if(hasA) h += '<span style="font-size:18px;font-weight:700">' + actual.s1 + ' - ' + actual.s2 + '</span>';
    else h += '<span class="match-vs">vs</span>';
    h += '</div><span class="team">' + m.team2 + '</span></div>';
    if(hasA) {
      h += '<div style="margin-top:10px;border-top:1px dashed var(--border);padding-top:8px"><div style="font-size:11px;color:var(--hint);margin-bottom:6px">Predictions:</div>';
      Object.keys(state.players || {}).filter(p => currentPlayer === ADMIN || p !== ADMIN).forEach(p => {
        const pred = state.predictions?.[p]?.['m' + m.id];
        if(!pred || !pred.locked) return;
        const r = calcPoints(pred, actual), cls = r ? (r.type === 'exact' ? 'result-exact' : r.type === 'correct' ? 'result-correct' : 'result-wrong') : '';
        h += '<div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;padding:2px 0"><span>' + chessIcon(p) + p + ': ' + pred.s1 + '-' + pred.s2 + '</span>';
        if(r) h += '<span class="result-badge ' + cls + '">+' + r.pts + '</span>';
        h += '</div>';
      });
      h += '</div>';
    }
    h += '</div>';
  });
  // Bonus actuals section (admin sets results, everyone sees them)
  h += '<div class="card" style="margin-top:20px"><h2>Bonus Predictions Results</h2>';
  if(isAdmin) h += '<p style="font-size:13px;color:var(--muted);margin-bottom:12px">Set the actual results for bonus categories.</p>';
  BONUS_CATS.forEach(cat => {
    const actual = bonusActuals[cat.id] || '';
    h += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap"><label style="min-width:200px;font-size:14px;font-weight:500">' + cat.label + '</label>';
    if(isAdmin) {
      if(cat.type === 'team') {
        h += '<select class="bonus-actual-input" data-cat="' + cat.id + '"><option value="">-- Select --</option>';
        TEAMS.forEach(t => h += '<option value="' + t + '"' + (actual === t ? ' selected' : '') + '>' + t + '</option>');
        h += '</select>';
      } else if(cat.type === 'match') {
        h += '<select class="bonus-actual-input" data-cat="' + cat.id + '"><option value="">-- Select --</option>';
        MATCHES.forEach(m => { const lbl = m.team1 + ' vs ' + m.team2; h += '<option value="m' + m.id + '"' + (actual === 'm' + m.id ? ' selected' : '') + '>' + lbl + '</option>'; });
        h += '</select>';
      } else {
        h += '<input type="text" class="bonus-actual-input" data-cat="' + cat.id + '" value="' + (actual || '') + '" placeholder="Enter actual result" style="max-width:250px"/>';
      }
    } else {
      h += '<span style="font-weight:600">' + (actual || '<span style="color:var(--hint)">TBD</span>') + '</span>';
    }
    h += '</div>';
    // Show all players' predictions for this category
    if(actual) {
      h += '<div style="margin-left:210px;margin-bottom:12px;font-size:13px">';
      Object.keys(bonusPredictions).filter(p => p !== '_' && (currentPlayer === ADMIN || p !== ADMIN)).forEach(p => {
        const pb = bonusPredictions[p];
        if(!pb || !pb._locked || !pb[cat.id]) return;
        const correct = pb[cat.id] === actual;
        let display = pb[cat.id];
        if(cat.type === 'match') { const mm = MATCHES.find(x => 'm' + x.id === pb[cat.id]); if(mm) display = mm.team1 + ' vs ' + mm.team2; }
        h += '<div style="display:flex;justify-content:space-between;max-width:400px"><span>' + p + ': ' + display + '</span><span class="result-badge ' + (correct ? 'result-exact' : 'result-wrong') + '">' + (correct ? '+' + BONUS_PTS : '0') + '</span></div>';
      });
      h += '</div>';
    }
  });
  h += '</div>';
  return h;
}

function renderLeaderboard() {
  const lb = getLeaderboard();
  if(!lb.length) return '<div class="card"><div class="empty">No players yet.</div></div>';
  const posChanges = getPositionChanges();
  let h = '<div class="card"><h2>Full leaderboard</h2><table><tr><th>#</th><th></th><th>Player</th><th style="text-align:right">Exact (3)</th><th style="text-align:right">Correct (1)</th><th style="text-align:right">Wrong</th><th style="text-align:right">Bonus</th><th style="text-align:right">Streak</th><th style="text-align:right">Points</th></tr>';
  lb.forEach((p, i) => {
    const streak = streakBadge(p.name);
    const achs = getAchievements(p.name);
    h += '<tr><td class="' + (i < 3 ? 'rank-' + (i + 1) : '') + '">' + (i + 1) + '</td>';
    h += '<td>' + posArrow(posChanges[p.name] || 0) + '</td>';
    h += '<td style="' + (p.name === currentPlayer ? 'font-weight:600' : '') + '">' + chessIcon(p.name) + p.name + ' ' + chessLabel(p.name) + (p.name === currentPlayer ? ' (you)' : '') + (streak ? ' ' + streak : '') + (achs ? '<br>' + achs : '') + '</td>';
    const streakDisplay = p.streakCurrent > 0 ? '&#128293;' + p.streakCurrent + (p.streakPts > 0 ? '' : '*') : '0';
    h += '<td style="text-align:right">' + p.exact + '</td><td style="text-align:right">' + p.correct + '</td><td style="text-align:right">' + p.wrong + '</td><td style="text-align:right">' + (p.bonusPts || 0) + '</td><td style="text-align:right">' + streakDisplay + '</td>';
    h += '<td style="text-align:right;font-weight:700;font-size:16px">' + p.total + '</td></tr>';
  });
  h += '</table></div>';
  lb.forEach(p => {
    const pct = p.predicted > 0 ? Math.round(((p.exact + p.correct) / p.predicted) * 100) : 0;
    const streak = getStreak(p.name);
    const achs = getAchievements(p.name);
    h += '<div class="card"><h2>' + chessIcon(p.name) + p.name + ' ' + chessLabel(p.name) + (p.name === currentPlayer ? ' (you)' : '') + '</h2>';
    if(achs) h += '<div style="margin-bottom:12px">' + achs + '</div>';
    h += '<div class="stats-row">';
    h += '<div class="stat-card"><div class="label">Accuracy</div><div class="value">' + pct + '%</div></div>';
    h += '<div class="stat-card"><div class="label">Points</div><div class="value">' + p.total + '</div></div>';
    h += '<div class="stat-card"><div class="label">Exact scores</div><div class="value">' + p.exact + '</div></div>';
    h += '<div class="stat-card"><div class="label">Streak</div><div class="value">' + (streak > 0 ? streak + ' &#128293;' : '0') + '</div></div>';
    h += '</div></div>';
  });
  return h;
}

function renderPlayers() {
  const players = Object.keys(state.players || {}), isAdmin = currentPlayer === ADMIN;
  let h = '<div class="card"><h2>Players (' + players.length + ')</h2><div class="player-list">';
  players.forEach(p => {
    const jt = joinTimes[p] ? new Date(joinTimes[p]).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
    if(p === ADMIN && !isAdmin) return; // Hide admin from other players
    h += '<div class="player-chip">' + chessIcon(p) + '<span>' + p + '</span>' + chessLabel(p) + (p === ADMIN && isAdmin ? '<span class="admin-badge">admin</span>' : '') + (isAdmin && jt ? '<span style="font-size:10px;color:var(--hint);margin-left:6px">joined ' + jt + '</span>' : '') + (isAdmin && p !== ADMIN ? '<span style="font-size:11px;color:var(--blue);cursor:pointer;margin-left:6px" onclick="resetPlayerPassword(\'' + p.replace(/'/g, "\\'") + '\')">reset pw</span><span class="remove" onclick="removePlayer(\'' + p.replace(/'/g, "\\'") + '\')">&times;</span>' : '') + '</div>';
  });
  h += '</div></div>';
  h += '<div class="card"><h2>Share this link</h2><p style="font-size:14px;color:var(--muted);margin-bottom:12px">Send this to your friends so they can join and predict:</p>';
  h += '<div style="display:flex;gap:8px"><input type="text" value="https://tsowho.github.io/wc2026-predictions" id="shareLink" readonly style="font-size:13px"/>';
  h += '<button class="btn-primary btn-sm" onclick="copyLink()">Copy</button></div></div>';
  h += '<div class="card"><h2>Your account</h2><p style="font-size:14px;color:var(--muted);margin-bottom:12px">Logged in as ' + chessIcon(currentPlayer) + '<strong>' + currentPlayer + '</strong> ' + chessLabel(currentPlayer) + '</p>';
  h += '<div style="display:flex;gap:8px;flex-wrap:wrap">';
  h += '<button class="btn-sm" onclick="logout()">Switch player</button>';
  if(currentPlayer !== ADMIN) h += '<button class="btn-sm" onclick="changeName()">Change name</button>';
  h += '<button class="btn-sm" onclick="changePassword()">Change password</button>';
  h += '</div></div>';
  return h;
}

window.lockBonus = function() {
  const myBonus = {};
  document.querySelectorAll('.bonus-input').forEach(el => { if(el.value) myBonus[el.dataset.cat] = el.value; });
  const filled = BONUS_CATS.filter(c => myBonus[c.id]);
  if(filled.length === 0) { alert('Fill in at least one bonus prediction before locking.'); return; }
  if(!confirm('Lock ' + filled.length + ' bonus prediction(s)? This cannot be changed!')) return;
  myBonus._locked = true;
  db.ref('wc2026/bonus/' + currentPlayer).set(myBonus);
};
window.lockPrediction = function(mid) {
  const s1 = document.querySelector('[data-match="' + mid + '"][data-side="s1"]')?.value;
  const s2 = document.querySelector('[data-match="' + mid + '"][data-side="s2"]')?.value;
  if(s1 === '' || s2 === '' || s1 === undefined || s2 === undefined) { alert('Enter both scores before locking.'); return; }
  const m = MATCHES.find(x => x.id === mid);
  if(!confirm('Lock prediction: ' + m.team1 + ' ' + s1 + ' - ' + s2 + ' ' + m.team2 + '?\n\nThis cannot be changed!')) return;
  db.ref('wc2026/predictions/' + currentPlayer + '/m' + mid).set({ s1: parseInt(s1), s2: parseInt(s2), locked: true, lockedAt: Date.now() });
};
window.removePlayer = function(name) { if(confirm('Remove ' + name + '?')) { db.ref('wc2026/players/' + name).remove(); db.ref('wc2026/predictions/' + name).remove(); db.ref('wc2026/passwords/' + name).remove(); db.ref('wc2026/joinTimes/' + name).remove(); db.ref('wc2026/bonus/' + name).remove(); db.ref('wc2026/loginDates/' + name).remove(); } };

window.resetPlayerPassword = function(name) {
  const newPw = prompt('Set new password for ' + name + ':');
  if(!newPw) return;
  db.ref('wc2026/passwords/' + name).set(newPw);
  alert('Password for ' + name + ' has been reset.');
};

window.changeName = function() {
  const newName = prompt('Enter your new name:');
  if(!newName || !newName.trim()) return;
  const trimmed = newName.trim();
  if(trimmed === currentPlayer) return;
  db.ref('wc2026/passwords/' + trimmed).once('value').then(snap => {
    if(snap.val()) { alert('That name is already taken.'); return; }
    // Copy data to new name
    const old = currentPlayer;
    Promise.all([
      db.ref('wc2026/passwords/' + old).once('value'),
      db.ref('wc2026/predictions/' + old).once('value'),
      db.ref('wc2026/joinTimes/' + old).once('value'),
      db.ref('wc2026/bonus/' + old).once('value'),
      db.ref('wc2026/loginDates/' + old).once('value')
    ]).then(([pwSnap, predSnap, jtSnap, bonusSnap, loginSnap]) => {
      const updates = {};
      updates['wc2026/players/' + trimmed] = true;
      updates['wc2026/players/' + old] = null;
      updates['wc2026/passwords/' + trimmed] = pwSnap.val();
      updates['wc2026/passwords/' + old] = null;
      updates['wc2026/predictions/' + trimmed] = predSnap.val();
      updates['wc2026/predictions/' + old] = null;
      updates['wc2026/joinTimes/' + trimmed] = jtSnap.val();
      updates['wc2026/joinTimes/' + old] = null;
      if(bonusSnap.val()) { updates['wc2026/bonus/' + trimmed] = bonusSnap.val(); updates['wc2026/bonus/' + old] = null; }
      if(loginSnap.val()) { updates['wc2026/loginDates/' + trimmed] = loginSnap.val(); updates['wc2026/loginDates/' + old] = null; }
      db.ref().update(updates).then(() => {
        currentPlayer = trimmed;
        localStorage.setItem('wc2026_player', trimmed);
        render();
        alert('Name changed to ' + trimmed + '!');
      });
    });
  });
};

window.changePassword = function() {
  db.ref('wc2026/passwords/' + currentPlayer).once('value').then(snap => {
    const current = prompt('Enter your current password:');
    if(current !== snap.val()) { alert('Wrong password.'); return; }
    const newPw = prompt('Enter new password:');
    if(!newPw) return;
    const confirm2 = prompt('Confirm new password:');
    if(newPw !== confirm2) { alert('Passwords don\'t match.'); return; }
    db.ref('wc2026/passwords/' + currentPlayer).set(newPw);
    alert('Password changed!');
  });
};
window.logout = function() { currentPlayer = null; localStorage.removeItem('wc2026_player'); document.getElementById('mainApp').classList.add('hidden'); document.getElementById('loginScreen').classList.remove('hidden'); updateExistingPlayers(); };
window.copyLink = function() { const inp = document.getElementById('shareLink'); navigator.clipboard.writeText(inp.value).then(() => { const btn = inp.nextElementSibling; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); }); };

function attachEvents() {
  document.querySelectorAll('.pred-input:not([disabled])').forEach(inp => {
    inp.addEventListener('change', e => {
      const mid = e.target.dataset.match, side = e.target.dataset.side, other = side === 's1' ? 's2' : 's1';
      const otherVal = document.querySelector('[data-match="' + mid + '"][data-side="' + other + '"]')?.value;
      const update = { locked: false };
      update[side] = e.target.value !== '' ? parseInt(e.target.value) : '';
      if(otherVal !== '' && otherVal !== undefined) update[other] = parseInt(otherVal);
      db.ref('wc2026/predictions/' + currentPlayer + '/m' + mid).update(update);
    });
  });
  document.querySelectorAll('.actual-input').forEach(inp => {
    inp.addEventListener('change', e => {
      const update = {}; update[e.target.dataset.side] = e.target.value !== '' ? parseInt(e.target.value) : null;
      db.ref('wc2026/actuals/m' + e.target.dataset.match).update(update);
    });
  });
  // Bonus prediction inputs (save on change, not locked yet)
  document.querySelectorAll('.bonus-input:not([disabled])').forEach(inp => {
    inp.addEventListener('change', e => {
      const cat = e.target.dataset.cat, val = e.target.value;
      if(val) db.ref('wc2026/bonus/' + currentPlayer + '/' + cat).set(val);
      else db.ref('wc2026/bonus/' + currentPlayer + '/' + cat).remove();
    });
  });
  // Bonus actual inputs (admin only)
  document.querySelectorAll('.bonus-actual-input').forEach(inp => {
    inp.addEventListener('change', e => {
      const cat = e.target.dataset.cat, val = e.target.value;
      if(val) db.ref('wc2026/bonusActuals/' + cat).set(val);
      else db.ref('wc2026/bonusActuals/' + cat).remove();
    });
  });
  // KO round filter
  var krf = document.getElementById('koRoundFilter');
  if(krf) krf.addEventListener('click', function(e) {
    if(!e.target.classList.contains('group-btn')) return;
    krf.querySelectorAll('.group-btn').forEach(function(b) { b.classList.remove('active'); });
    e.target.classList.add('active');
    var r = e.target.dataset.round;
    document.querySelectorAll('.ko-round-section').forEach(function(s) { s.style.display = r === 'all' || s.dataset.koround === r ? '' : 'none'; });
  });
  // Chat input enter key
  var chatIn = document.getElementById('chatInput');
  if(chatIn) { chatIn.addEventListener('keydown', function(e) { if(e.key === 'Enter') sendChat(); }); setTimeout(function(){ var cm = document.getElementById('chatMessages'); if(cm) cm.scrollTop = cm.scrollHeight; }, 50); }
  const gf = document.getElementById('groupFilter');
  if(gf) gf.addEventListener('click', e => {
    if(!e.target.classList.contains('group-btn')) return;
    gf.querySelectorAll('.group-btn').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    const g = e.target.dataset.group;
    document.querySelectorAll('.match-card').forEach(mc => { mc.style.display = g === 'all' || mc.dataset.group === g ? '' : 'none'; });
  });
}



// === KNOCKOUT STAGE ===
const KO_ROUNDS = [
  { id: 'r32', name: 'Round of 32', matches: 16 },
  { id: 'r16', name: 'Round of 16', matches: 8 },
  { id: 'qf', name: 'Quarter-Finals', matches: 4 },
  { id: 'sf', name: 'Semi-Finals', matches: 2 },
  { id: '3rd', name: '3rd Place', matches: 1 },
  { id: 'final', name: 'Final', matches: 1 }
];

// R32 matchups based on FIFA format: group winners vs third-place, runners-up vs runners-up
const KO_SLOTS = [];
// Round of 32 (16 matches)
for(var ki = 1; ki <= 16; ki++) KO_SLOTS.push({ id: 'r32_' + ki, round: 'r32', num: ki, team1: 'TBD', team2: 'TBD', date: '', time: '' });
// Round of 16
for(var ki = 1; ki <= 8; ki++) KO_SLOTS.push({ id: 'r16_' + ki, round: 'r16', num: ki, team1: 'TBD', team2: 'TBD', date: '', time: '' });
// QF
for(var ki = 1; ki <= 4; ki++) KO_SLOTS.push({ id: 'qf_' + ki, round: 'qf', num: ki, team1: 'TBD', team2: 'TBD', date: '', time: '' });
// SF
for(var ki = 1; ki <= 2; ki++) KO_SLOTS.push({ id: 'sf_' + ki, round: 'sf', num: ki, team1: 'TBD', team2: 'TBD', date: '', time: '' });
// 3rd place + Final
KO_SLOTS.push({ id: '3rd_1', round: '3rd', num: 1, team1: 'TBD', team2: 'TBD', date: '', time: '' });
KO_SLOTS.push({ id: 'final_1', round: 'final', num: 1, team1: 'TBD', team2: 'TBD', date: '', time: '' });

let koTeams = {};
let koPredictions = {};
let koActuals = {};

stateRef.child('knockout/teams').on('value', snap => { koTeams = snap.val() || {}; if(currentPlayer) render(); });
stateRef.child('knockout/predictions').on('value', snap => { koPredictions = snap.val() || {}; if(currentPlayer) render(); });
stateRef.child('knockout/actuals').on('value', snap => { koActuals = snap.val() || {}; if(currentPlayer) render(); });

function getKoMatch(id) {
  var slot = KO_SLOTS.find(function(s) { return s.id === id; });
  if(!slot) return null;
  var teams = koTeams[id] || {};
  return { id: id, round: slot.round, num: slot.num, team1: teams.team1 || 'TBD', team2: teams.team2 || 'TBD', date: teams.date || '', time: teams.time || '' };
}

function renderKnockout() {
  var isAdmin = currentPlayer === ADMIN;
  var now = new Date();
  var h = '<div class="card" style="margin-bottom:16px"><h2>Knockout Stage</h2>';
  h += '<p style="font-size:13px;color:var(--muted)">Teams and dates will be set by admin as the group stage finishes. Predict scores once matchups are confirmed!</p>';
  if(isAdmin) h += '<p style="font-size:12px;color:var(--accent);margin-top:6px">Admin: click team names to set matchups.</p>';
  h += '</div>';

  // Round filter
  h += '<div class="group-filter" id="koRoundFilter" style="margin-bottom:16px"><button class="group-btn active" data-round="all">All</button>';
  KO_ROUNDS.forEach(function(r) { h += '<button class="group-btn" data-round="' + r.id + '">' + r.name + '</button>'; });
  h += '</div>';

  KO_ROUNDS.forEach(function(round) {
    h += '<div class="ko-round-section" data-koround="' + round.id + '"><h3 style="margin:16px 0 8px;font-size:15px;color:var(--accent)">' + round.name + '</h3>';
    var matches = KO_SLOTS.filter(function(s) { return s.round === round.id; });
    matches.forEach(function(slot) {
      var m = getKoMatch(slot.id);
      var hasBothTeams = m.team1 !== 'TBD' && m.team2 !== 'TBD';
      var actual = koActuals[slot.id] || {};
      var hasResult = actual.s1 !== undefined && actual.s1 !== '';
      var pred = koPredictions[currentPlayer] ? koPredictions[currentPlayer][slot.id] : null;
      var predObj = pred || {};
      var locked = predObj.locked;
      var matchStarted = m.date && m.time ? new Date() >= new Date(m.date + 'T' + m.time + ':00-04:00') : false;

      h += '<div class="match-card" data-koround="' + round.id + '">';
      h += '<div class="match-header"><span>' + round.name + ' #' + slot.num + (m.date ? ' | ' + fmtDate(m.date) + ' ' + m.time + ' ET' : '') + '</span>';
      if(locked) h += '<span class="locked-badge">Locked</span>';
      else if(hasResult) h += '<span class="result-badge result-exact">Final</span>';
      else if(!hasBothTeams) h += '<span style="font-size:11px;color:var(--muted)">Awaiting teams</span>';
      else if(matchStarted) h += '<span style="font-size:11px;color:var(--danger)">Started</span>';
      h += '</div>';

      h += '<div class="match-teams">';
      if(isAdmin && !hasResult) {
        h += '<span class="team" style="cursor:pointer;text-decoration:underline dotted" onclick="setKoTeam(\'' + slot.id + '\',1)">' + m.team1 + '</span>';
      } else {
        h += '<span class="team">' + m.team1 + '</span>';
      }
      h += '<div class="match-score">';

      if(hasResult) {
        h += '<span style="font-size:18px;font-weight:700">' + actual.s1 + ' - ' + actual.s2 + '</span>';
      } else if(hasBothTeams) {
        var canPredict = !locked && !matchStarted && !hasResult;
        h += '<input type="number" min="0" max="20" value="' + (predObj.s1 != null ? predObj.s1 : '') + '" data-ko="' + slot.id + '" data-side="s1" class="ko-input"' + (!canPredict ? ' disabled' : '') + '/>';
        h += '<span class="match-vs">-</span>';
        h += '<input type="number" min="0" max="20" value="' + (predObj.s2 != null ? predObj.s2 : '') + '" data-ko="' + slot.id + '" data-side="s2" class="ko-input"' + (!canPredict ? ' disabled' : '') + '/>';
        if(canPredict) h += '<button class="btn-lock" onclick="lockKoPrediction(\'' + slot.id + '\')">Lock</button>';
      } else {
        h += '<span class="match-vs">vs</span>';
      }

      h += '</div>';
      if(isAdmin && !hasResult) {
        h += '<span class="team" style="cursor:pointer;text-decoration:underline dotted" onclick="setKoTeam(\'' + slot.id + '\',2)">' + m.team2 + '</span>';
      } else {
        h += '<span class="team">' + m.team2 + '</span>';
      }
      h += '</div>';

      // Show result points if both prediction and actual exist
      if(hasResult && pred && pred.locked) {
        var r = calcPoints(pred, actual);
        if(r) {
          var cls = r.type === 'exact' ? 'result-exact' : r.type === 'correct' ? 'result-correct' : 'result-wrong';
          var lbl = r.type === 'exact' ? 'Exact! +3' : r.type === 'correct' ? 'Correct result +1' : 'Wrong 0';
          h += '<div style="text-align:center;margin-top:8px"><span class="result-badge ' + cls + '">' + lbl + '</span></div>';
        }
      }

      // Admin: enter actual result
      if(isAdmin && hasBothTeams) {
        h += '<div style="margin-top:8px;padding-top:8px;border-top:1px dashed var(--border);display:flex;align-items:center;gap:8px;justify-content:center">';
        h += '<span style="font-size:11px;color:var(--muted)">Result:</span>';
        h += '<input type="number" min="0" max="20" value="' + (actual.s1 != null ? actual.s1 : '') + '" data-koactual="' + slot.id + '" data-side="s1" class="ko-actual-input" style="width:50px"/>';
        h += '<span>-</span>';
        h += '<input type="number" min="0" max="20" value="' + (actual.s2 != null ? actual.s2 : '') + '" data-koactual="' + slot.id + '" data-side="s2" class="ko-actual-input" style="width:50px"/>';
        h += '<button class="btn-primary" style="padding:4px 10px;font-size:11px" onclick="saveKoResult(\'' + slot.id + '\')">Save</button>';
        h += '</div>';
      }

      h += '</div>';
    });
    h += '</div>';
  });
  return h;
}

// Knockout actions
window.setKoTeam = function(slotId, side) {
  var current = (koTeams[slotId] || {})['team' + side] || '';
  var team = prompt('Enter team name for ' + (side === 1 ? 'Home' : 'Away') + ':', current === 'TBD' ? '' : current);
  if(team === null) return;
  team = team.trim();
  if(!team) return;
  db.ref('wc2026/knockout/teams/' + slotId + '/team' + side).set(team);
};

window.lockKoPrediction = function(slotId) {
  var s1El = document.querySelector('[data-ko="' + slotId + '"][data-side="s1"]');
  var s2El = document.querySelector('[data-ko="' + slotId + '"][data-side="s2"]');
  if(!s1El || !s2El) return;
  var s1 = s1El.value, s2 = s2El.value;
  if(s1 === '' || s2 === '') { alert('Enter both scores before locking.'); return; }
  if(!confirm('Lock prediction ' + s1 + '-' + s2 + '? Cannot be changed!')) return;
  db.ref('wc2026/knockout/predictions/' + currentPlayer + '/' + slotId).set({ s1: parseInt(s1), s2: parseInt(s2), locked: true });
};

window.saveKoResult = function(slotId) {
  var s1El = document.querySelector('[data-koactual="' + slotId + '"][data-side="s1"]');
  var s2El = document.querySelector('[data-koactual="' + slotId + '"][data-side="s2"]');
  if(!s1El || !s2El) return;
  var s1 = s1El.value, s2 = s2El.value;
  if(s1 === '' || s2 === '') { alert('Enter both scores.'); return; }
  db.ref('wc2026/knockout/actuals/' + slotId).set({ s1: parseInt(s1), s2: parseInt(s2) });
};

// Admin can also set date/time for KO matches
window.setKoDateTime = function(slotId) {
  var current = koTeams[slotId] || {};
  var date = prompt('Date (YYYY-MM-DD):', current.date || '');
  if(date === null) return;
  var time = prompt('Time ET (HH:MM):', current.time || '');
  if(time === null) return;
  var updates = {};
  if(date) updates['wc2026/knockout/teams/' + slotId + '/date'] = date;
  if(time) updates['wc2026/knockout/teams/' + slotId + '/time'] = time;
  if(Object.keys(updates).length) db.ref().update(updates);
};

// === CHAT SECTION ===
function renderChat() {
  let h = '<div class="card" style="margin-bottom:16px"><h2>Chat</h2><p style="font-size:13px;color:var(--muted)">Talk trash, share tips, celebrate wins. Be nice!</p></div>';
  h += '<div class="card" style="padding:0;overflow:hidden">';
  h += '<div id="chatMessages" style="height:400px;overflow-y:auto;padding:12px 16px;display:flex;flex-direction:column;gap:8px">';
  if(chatMessages.length === 0) {
    h += '<div class="empty" style="padding:40px">No messages yet. Start the conversation!</div>';
  } else {
    chatMessages.forEach(function(msg) {
      var isMe = msg.name === currentPlayer;
      var isAdmin = msg.name === ADMIN;
      var time = new Date(msg.ts);
      var timeStr = time.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'America/New_York' });
      var rank = getChessRank(msg.name);
      h += '<div style="display:flex;align-items:flex-start;gap:8px;' + (isMe ? 'flex-direction:row-reverse;text-align:right' : '') + '">';
      h += '<div style="flex-shrink:0;width:32px;height:32px;border-radius:50%;background:' + (isMe ? 'var(--accent)' : 'var(--border)') + ';display:flex;align-items:center;justify-content:center;font-size:16px">' + rank.piece + '</div>';
      h += '<div style="max-width:75%;padding:8px 12px;border-radius:12px;background:' + (isMe ? 'var(--accent)' : 'rgba(var(--accent-rgb,52,152,219),0.1)') + ';' + (isMe ? 'color:#fff;border-bottom-right-radius:4px' : 'border-bottom-left-radius:4px') + '">';
      h += '<div style="font-size:11px;font-weight:600;margin-bottom:2px;' + (isMe ? 'color:rgba(255,255,255,0.8)' : 'color:var(--accent)') + '">' + msg.name + '</div>';
      h += '<div style="font-size:14px;word-break:break-word">' + escapeHtml(msg.text) + '</div>';
      h += '<div style="font-size:10px;margin-top:3px;' + (isMe ? 'color:rgba(255,255,255,0.5)' : 'color:var(--muted)') + '">' + timeStr + '</div>';
      h += '</div></div>';
    });
  }
  h += '</div>';
  h += '<div style="display:flex;gap:8px;padding:12px 16px;border-top:1px solid var(--border);background:var(--card)">';
  h += '<input type="text" id="chatInput" placeholder="Type a message..." style="flex:1;padding:8px 12px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:14px" maxlength="300" />';
  h += '<button class="btn-primary" onclick="sendChat()" style="padding:8px 16px">Send</button>';
  h += '</div></div>';
  return h;
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

window.sendChat = function() {
  var input = document.getElementById('chatInput');
  if(!input) return;
  var text = input.value.trim();
  if(!text || !currentPlayer) return;
  db.ref('wc2026/chat').push({ name: currentPlayer, text: text, ts: firebase.database.ServerValue.TIMESTAMP });
  input.value = '';
};

// === HERO DASHBOARD ===
function getTrashTalk() {
  const lb = getLeaderboard(true);
  const msgs = [];
  const leader = lb[0];
  if(leader && leader.total > 0) msgs.push(chessIcon(leader.name) + ' ' + leader.name + ' sits on the throne with ' + leader.total + ' pts!');
  lb.forEach(p => {
    const s = getStreak(p.name);
    if(s >= 3) msgs.push(p.name + ' is on a ' + s + '-match hot streak!');
    const ls = getLoseStreak(p.name);
    if(ls >= 3) msgs.push(p.name + ' can\'t catch a break... ' + ls + ' wrong in a row!');
  });
  const noLock = Object.keys(state.players || {}).filter(p => {
    const preds = state.predictions?.[p];
    if(!preds) return true;
    return !Object.values(preds).some(v => v.locked);
  });
  noLock.forEach(p => msgs.push(p + ' hasn\'t locked a single prediction yet!'));
  if(lb.length >= 2 && lb[0].total > 0 && lb[0].total === lb[1].total) msgs.push('It\'s a tie at the top! ' + lb[0].name + ' vs ' + lb[1].name + ' — who blinks first?');
  const played = Object.keys(state.actuals || {}).length;
  if(played === 0) msgs.push('The tournament hasn\'t started yet — lock your predictions now!');
  // Login streak trash talk
  const now = new Date();
  if(now >= WC_START && now <= WC_END) {
    lb.forEach(p => {
      const si = getStreakInfo(p.name);
      if(si.streak >= 10) msgs.push(p.name + ' has a ' + si.streak + '-day login streak! Dedicated!');
      if(si.streak === 0 && si.days.length > 0 && si.days.some(d => d.logged)) msgs.push(p.name + ' broke their login streak! Back to zero!');
    });
  }
  if(msgs.length === 0) msgs.push('Who will be crowned the prediction King?');
  return msgs;
}

let trashIdx = 0;
let trashMsgs = [];

function buildStreakBar() {
  const now = new Date();
  const si = getStreakInfo(currentPlayer);
  if(!si.started) {
    // Before tournament
    const diff = WC_START - now;
    const d = Math.floor(diff / 86400000);
    return '<div class="streak-teaser">' +
      '<div class="gift-wrap"><div class="gift-lid"></div><div class="gift-box"><div class="gift-ribbon-v"></div><div class="gift-ribbon-h"></div></div><div class="gift-sparkle"></div><div class="gift-sparkle"></div><div class="gift-sparkle"></div></div>' +
      '<div class="streak-teaser-text"><div class="streak-teaser-title">Something is brewing... login streak starts June 11</div><div class="streak-teaser-sub">' + d + ' days \u2014 log in every day during the World Cup for bonus points!</div></div>' +
      '<div class="cauldron-wrap"><div class="cauldron-rim"></div><div class="cauldron-body"><div class="cauldron-liquid"><div class="cauldron-bubble"></div><div class="cauldron-bubble"></div><div class="cauldron-bubble"></div></div></div><div class="cauldron-steam"></div><div class="cauldron-steam"></div><div class="cauldron-steam"></div></div>' +
      '</div>';
  }
  // During or after tournament
  const today = getETDate();
  const claimedToday = !!(loginDates[currentPlayer] && loginDates[currentPlayer][today]);
  let h = '<div class="hero-streak">';
  h += '<div style="display:flex;align-items:center;gap:6px"><span class="' + (si.streak > 0 ? 'streak-fire' : '') + '">' + (si.streak > 0 ? '&#128293;' : '&#128167;') + '</span>';
  h += '<div><div class="streak-count">' + si.streak + '</div><div class="streak-label-sm">' + (si.streak === 0 && si.days.length > 0 && si.days.some(function(d){return d.logged;}) ? 'streak broken' : 'day streak') + '</div></div></div>';
  // Claim button
  if(!si.tournamentOver) {
    if(claimedToday) {
      h += '<button class="streak-claim-btn claimed" disabled>Claimed today &#10003;</button>';
    } else {
      h += '<button class="streak-claim-btn available" onclick="claimStreak()">Claim today\'s streak</button>';
    }
  }
  // Day squares
  h += '<div class="streak-days-row">';
  // Show all 39 tournament days
  const allDays = [];
  const dd = new Date(WC_START);
  while(dd <= WC_END) {
    allDays.push(dd.toLocaleDateString('en-CA', { timeZone: 'America/New_York' }));
    dd.setDate(dd.getDate() + 1);
  }
  allDays.forEach(day => {
    const playerDates = loginDates[currentPlayer] || {};
    const logged = !!playerDates[day];
    const isToday = day === today;
    const isFuture = day > today;
    const isPast = day < today;
    let cls = 'streak-sq';
    if(isToday && logged) cls += ' today on';
    else if(isToday && !logged) cls += ' today';
    else if(isFuture) cls += ' future';
    else if(logged) cls += ' on';
    else if(isPast) cls += ' miss';
    h += '<div class="' + cls + '" title="' + day + '"></div>';
  });
  h += '</div>';
  // Streak pts info
  if(si.tournamentOver) {
    h += '<div style="text-align:right"><div class="streak-badge-hero">+' + si.streak + ' pts added</div></div>';
  } else {
    h += '<div style="text-align:right;min-width:70px"><div style="font-size:11px;opacity:0.7">+' + si.streak + ' pts banked</div><div style="font-size:9px;opacity:0.4">' + (claimedToday ? 'come back tomorrow!' : 'resets at midnight ET') + '</div></div>';
  }
  h += '</div>';
  return h;
}

var _heroHash = '';
function renderHero() {
  const el = document.getElementById('heroDashboard');
  if(!el || !currentPlayer) return;
  // Only rebuild DOM when data changes - prevents CSS animation resets
  var dataHash = JSON.stringify([
    Object.keys(state.players || {}),
    Object.keys(state.actuals || {}),
    Object.keys(state.predictions || {}),
    Object.keys(bonusPredictions || {}),
    currentPlayer
  ]);
  if(dataHash === _heroHash && el.innerHTML !== '') return;
  _heroHash = dataHash;
  const lb = getLeaderboard(true);
  const me = lb.find(p => p.name === currentPlayer) || { total: 0, exact: 0, correct: 0, predicted: 0 };
  const myPos = lb.indexOf(me) + 1;
  const rank = getChessRank(currentPlayer);
  const played = Object.keys(state.actuals || {}).length;
  const pct = MATCHES.length > 0 ? Math.round((played / MATCHES.length) * 100) : 0;
  const now = new Date();

  // Find live and next match
  const liveMatches = MATCHES.filter(m => { const t = getMatchTime(m); return now >= t && now <= new Date(t.getTime() + 7200000) && !state.actuals?.['m' + m.id]; });
  const nextMatch = MATCHES.find(m => !state.actuals?.['m' + m.id] && !liveMatches.includes(m) && getMatchTime(m) > now);

  // Ticker items
  let tickerItems = [];
  // Recent results
  const results = MATCHES.filter(m => state.actuals?.['m' + m.id]).slice(-6);
  results.forEach(m => {
    const a = state.actuals['m' + m.id];
    tickerItems.push('<span class="hero-ticker-item"><span class="ticker-dot"></span>' + m.team1 + ' ' + a.s1 + '-' + a.s2 + ' ' + m.team2 + '</span>');
  });
  if(liveMatches.length) {
    liveMatches.forEach(m => {
      tickerItems.push('<span class="hero-ticker-item"><span class="ticker-dot ticker-live"></span>LIVE: ' + m.team1 + ' vs ' + m.team2 + '</span>');
    });
  }
  // Top players
  lb.slice(0, 3).forEach((p, i) => {
    const medals = ['&#9733;', '&#9734;', '&#9672;'];
    tickerItems.push('<span class="hero-ticker-item"><span class="ticker-dot" style="background:' + ['#BA7517','#888','#a0522d'][i] + '"></span>' + medals[i] + ' ' + p.name + ' ' + p.total + 'pts</span>');
  });
  if(tickerItems.length === 0) tickerItems.push('<span class="hero-ticker-item"><span class="ticker-dot"></span>World Cup 2026 — Predictions open!</span>');
  const tickerHtml = tickerItems.join('') + tickerItems.join(''); // double for seamless scroll

  // Particles
  let particles = '';
  for(let i = 0; i < 12; i++) {
    const left = Math.random() * 100, delay = Math.random() * 8, size = 2 + Math.random() * 4;
    particles += '<div class="hero-particle" style="left:' + left + '%;animation-delay:' + delay + 's;width:' + size + 'px;height:' + size + 'px"></div>';
  }

  // Center: countdown or live
  let centerHtml = '';
  if(liveMatches.length) {
    const lm = liveMatches[0];
    centerHtml = '<div class="hero-next-label">Match in progress</div>';
    centerHtml += '<div class="hero-next-teams">' + lm.team1 + ' vs ' + lm.team2 + '</div>';
    centerHtml += '<div class="hero-next-meta">Group ' + lm.group + ' | ' + lm.venue + '</div>';
    centerHtml += '<div class="hero-live-now"><span class="hero-live-pulse"></span> LIVE NOW</div>';
  } else if(nextMatch) {
    const diff = getMatchTime(nextMatch) - now;
    const d = Math.floor(diff / 86400000), h = Math.floor((diff % 86400000) / 3600000), min = Math.floor((diff % 3600000) / 60000), s = Math.floor((diff % 60000) / 1000);
    centerHtml = '<div class="hero-next-label">Next match</div>';
    centerHtml += '<div class="hero-next-teams">' + nextMatch.team1 + ' vs ' + nextMatch.team2 + '</div>';
    centerHtml += '<div class="hero-next-meta">Group ' + nextMatch.group + ' | ' + fmtDate(nextMatch.date) + ' ' + nextMatch.time + ' ET</div>';
    centerHtml += '<div class="hero-countdown">';
    if(d > 0) centerHtml += '<div class="hero-cd-box"><div class="hero-cd-num" id="cdDays">' + d + '</div><div class="hero-cd-unit">days</div></div>';
    centerHtml += '<div class="hero-cd-box"><div class="hero-cd-num" id="cdHrs">' + h + '</div><div class="hero-cd-unit">hrs</div></div>';
    centerHtml += '<div class="hero-cd-box"><div class="hero-cd-num" id="cdMin">' + min + '</div><div class="hero-cd-unit">min</div></div>';
    centerHtml += '<div class="hero-cd-box"><div class="hero-cd-num" id="cdSec">' + s + '</div><div class="hero-cd-unit">sec</div></div>';
    centerHtml += '</div>';
  } else {
    centerHtml = '<div class="hero-next-label">Tournament</div><div class="hero-next-teams">Complete!</div>';
  }

  // Podium
  let podiumHtml = '<div class="hero-podium-title">Leaderboard</div><div class="podium-row">';
  const podiumOrder = [1, 0, 2]; // 2nd, 1st, 3rd visual order
  podiumOrder.forEach(i => {
    const p = lb[i];
    if(!p || p.total === 0) { podiumHtml += '<div class="podium-spot podium-' + (i + 1) + '"><div class="podium-piece">-</div><div class="podium-name">-</div></div>'; return; }
    const r = getChessRank(p.name);
    podiumHtml += '<div class="podium-spot podium-' + (i + 1) + '"><div class="podium-piece">' + r.piece + '</div><div class="podium-name">' + p.name + '</div><div class="podium-pts">' + p.total + ' pts</div></div>';
  });
  podiumHtml += '</div>';

  // Trash talk merged into ticker
  trashMsgs = getTrashTalk();
  trashMsgs.forEach(function(msg) {
    tickerItems.push('<span class="hero-ticker-item"><span class="ticker-dot" style="background:#e24b4a"></span>' + msg + '</span>');
  });
  var fullTickerHtml = tickerItems.join('') + tickerItems.join('');

  const bounceBall = '<div class="hero-ball-x"><div class="hero-ball-y"><div class="hero-ball">&#9917;</div></div></div>';

  // Burning fuse under countdown
  var fuseHtml = '';
  if(nextMatch && !liveMatches.length) {
    var diff2 = getMatchTime(nextMatch) - now;
    var burnPct = Math.max(0, Math.min(100, (1 - diff2 / (7 * 86400000)) * 100));
    fuseHtml = '<div class="fuse-wrap"><div class="fuse-label">&#9200;</div><div class="fuse-line"><div class="fuse-burned" style="width:' + burnPct + '%"></div><div class="fuse-spark" style="left:calc(' + burnPct + '% - 4px)"><div class="fuse-sparks"><div class="fuse-spark-p" style="--sx:6px;--sy:-10px"></div><div class="fuse-spark-p" style="--sx:-4px;--sy:-12px"></div><div class="fuse-spark-p" style="--sx:3px;--sy:-8px"></div></div></div></div><div class="fuse-bomb">&#128163;</div></div>';
  }

  el.innerHTML = '<div class="pitch-center"></div><div class="pitch-box-l"></div><div class="pitch-box-r"></div>' +
    '<div class="hero-particles">' + particles + '</div>' + bounceBall +
    '<div class="hero-ticker"><div class="hero-ticker-inner">' + fullTickerHtml + '</div></div>' +
    '<div class="hero-body">' +
      '<div class="hero-stats">' +
        '<div style="display:flex;align-items:center;gap:12px"><span class="hero-chess">' + rank.piece + '</span><div><div class="hero-name">' + currentPlayer + '</div><div class="hero-rank-label">' + rank.name + (myPos > 0 && me.total > 0 ? ' \u2014 #' + myPos : '') + '</div></div></div>' +
        '<div class="hero-stat-row"><div><div class="hero-stat-num">' + me.total + '</div><div class="hero-stat-label">Points</div></div><div><div class="hero-stat-num">' + me.exact + '</div><div class="hero-stat-label">Exact</div></div><div><div class="hero-stat-num">' + me.predicted + '</div><div class="hero-stat-label">Predicted</div></div></div>' +
      '</div>' +
      '<div class="hero-center">' + centerHtml + fuseHtml + '</div>' +
      '<div class="hero-podium">' + podiumHtml + '</div>' +
    '</div>' +
    '<div class="hero-progress"><span class="hero-progress-label">Tournament</span><div class="hero-progress-bar"><div class="hero-progress-fill" style="width:' + pct + '%"></div></div><span class="hero-progress-label">' + played + '/' + MATCHES.length + '</span></div>' +
    buildStreakBar();
}

// Live countdown ticker
setInterval(() => {
  const cdDays = document.getElementById('cdDays');
  const cdHrs = document.getElementById('cdHrs');
  const cdMin = document.getElementById('cdMin');
  const cdSec = document.getElementById('cdSec');
  if(!cdSec) return;
  const now = new Date();
  const liveMatches = MATCHES.filter(m => { const t = getMatchTime(m); return now >= t && now <= new Date(t.getTime() + 7200000) && !state.actuals?.['m' + m.id]; });
  const nextMatch = MATCHES.find(m => !state.actuals?.['m' + m.id] && !liveMatches.includes(m) && getMatchTime(m) > now);
  if(!nextMatch) return;
  const diff = getMatchTime(nextMatch) - now;
  if(diff <= 0) { renderHero(); return; }
  const d = Math.floor(diff / 86400000), h = Math.floor((diff % 86400000) / 3600000), min = Math.floor((diff % 3600000) / 60000), s = Math.floor((diff % 60000) / 1000);
  if(cdDays) cdDays.textContent = d;
  if(cdHrs) cdHrs.textContent = h;
  if(cdMin) cdMin.textContent = min;
  cdSec.textContent = s;
}, 1000);

// Patch render to also update hero
const _origRender = render;
render = function() { renderHero(); _origRender(); };

setInterval(() => { if(currentTab === 'live') render(); }, 30000);
render();

// World Cup winners background with flag colors
(function() {
  const winners = [
    {y:'1930',t:'Uruguay',f:'🇺🇾',c1:'#0038A8',c2:'#FFFFFF'},
    {y:'1934',t:'Italy',f:'🇮🇹',c1:'#008C45',c2:'#CD212A'},
    {y:'1938',t:'Italy',f:'🇮🇹',c1:'#008C45',c2:'#CD212A'},
    {y:'1950',t:'Uruguay',f:'🇺🇾',c1:'#0038A8',c2:'#FFFFFF'},
    {y:'1954',t:'Germany',f:'🇩🇪',c1:'#FFCC00',c2:'#DD0000'},
    {y:'1958',t:'Brazil',f:'🇧🇷',c1:'#009C3B',c2:'#FFDF00'},
    {y:'1962',t:'Brazil',f:'🇧🇷',c1:'#009C3B',c2:'#FFDF00'},
    {y:'1966',t:'England',f:'🏴󠁧󠁢󠁥󠁮󠁧󠁿',c1:'#FFFFFF',c2:'#CF081F'},
    {y:'1970',t:'Brazil',f:'🇧🇷',c1:'#009C3B',c2:'#FFDF00'},
    {y:'1974',t:'Germany',f:'🇩🇪',c1:'#FFCC00',c2:'#DD0000'},
    {y:'1978',t:'Argentina',f:'🇦🇷',c1:'#74ACDF',c2:'#FFFFFF'},
    {y:'1982',t:'Italy',f:'🇮🇹',c1:'#008C45',c2:'#CD212A'},
    {y:'1986',t:'Argentina',f:'🇦🇷',c1:'#74ACDF',c2:'#FFFFFF'},
    {y:'1990',t:'Germany',f:'🇩🇪',c1:'#DD0000',c2:'#FFCC00'},
    {y:'1994',t:'Brazil',f:'🇧🇷',c1:'#009C3B',c2:'#FFDF00'},
    {y:'1998',t:'France',f:'🇫🇷',c1:'#002395',c2:'#ED2939'},
    {y:'2002',t:'Brazil',f:'🇧🇷',c1:'#009C3B',c2:'#FFDF00'},
    {y:'2006',t:'Italy',f:'🇮🇹',c1:'#008C45',c2:'#CD212A'},
    {y:'2010',t:'Spain',f:'🇪🇸',c1:'#AA151B',c2:'#F1BF00'},
    {y:'2014',t:'Germany',f:'🇩🇪',c1:'#DD0000',c2:'#FFCC00'},
    {y:'2018',t:'France',f:'🇫🇷',c1:'#002395',c2:'#ED2939'},
    {y:'2022',t:'Argentina',f:'🇦🇷',c1:'#74ACDF',c2:'#FFFFFF'}
  ];
  const track = document.getElementById('wcBgTrack');
  function buildItems() {
    return winners.map(w =>
      '<div class="wc-bg-item">' +
        '<div class="wc-bg-year" style="background:linear-gradient(135deg,' + w.c1 + ',' + w.c2 + ');-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">' + w.y + '</div>' +
        '<div class="wc-bg-team" style="color:' + w.c1 + '">' + w.t + '</div>' +
      '</div>'
    ).join('');
  }
  track.innerHTML = buildItems() + buildItems();
})();
</script>
</body>
</html>
